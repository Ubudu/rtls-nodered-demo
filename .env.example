# Copy this file to ".env" and fill in your values:
#   cp .env.example .env

# ---- RTLS connection (REQUIRED) --------------------------------------------
# Your Ubudu RTLS app namespace UUID and API key.
RTLS_NAMESPACE=your-app-namespace-uuid
RTLS_API_KEY=your-rtls-api-key

# Base URL of the RTLS API. Default points at the Ubudu cloud.
RTLS_BASE_URL=https://rtls.ubudu.com/api

# ---- Polling ---------------------------------------------------------------
# How often (in seconds) to poll the last positions.
POLL_INTERVAL_SEC=5

# ---- Optional MQTT re-publish ----------------------------------------------
# Set MQTT_ENABLE=true to publish per-tag zone events to an MQTT broker.
# To use the bundled broker, uncomment the "mqtt" service in docker-compose.yml
# and keep MQTT_HOST=mqtt.
MQTT_ENABLE=false
MQTT_TOPIC=ubudu/rtls/zones
MQTT_HOST=mqtt
MQTT_PORT=1883
